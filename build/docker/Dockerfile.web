# Use Node.js 22 as base image
FROM node:22-alpine AS builder

# Set working directory
WORKDIR /app

# Install pnpm
RUN npm install -g pnpm

# Configure Chinese mirror for npm and pnpm
RUN npm config set registry https://registry.npmmirror.com/ && pnpm config set registry https://registry.npmmirror.com/

# Copy package files
COPY package*.json ./

# Install dependencies
RUN pnpm install

# Copy source code
COPY . .

# Build web application
RUN npx vite build --config vite.admin.config.ts

# Use Nginx as production server
FROM nginx:alpine AS production

# Copy built files from builder stage
COPY --from=builder /app/dist-web /usr/share/nginx/html

# Copy nginx configuration
COPY build/docker/nginx.conf /etc/nginx/conf.d/default.conf

# Expose port
EXPOSE 80

# Start nginx
CMD ["nginx", "-g", "daemon off;"]