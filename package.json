{
	"name": "typix",
	"private": true,
	"version": "1.0.9",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"web": "vite --config vite.web.config.ts",
		"dev:worker": "wrangler dev",
		"build": "tsc -b && cross-env RUNTIME=cloudflare vite build",
		"build:node": "tsc -b && vite build && tsup --minify",
		"build:web": "tsc -b && vite build --config vite.web.config.ts",
		"analyze": "vite build --mode analyze",
		"fmt": "biome format --write .",
		"lint": "eslint .",
		"preview": "vite preview",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:admin:generate": "DRIZZLE_TARGET=admin drizzle-kit generate",
		"db:admin:migrate": "DRIZZLE_TARGET=admin drizzle-kit migrate",
		"db:admin:push": "DRIZZLE_TARGET=admin drizzle-kit push",
		"db:migrate:dev:worker": "wrangler d1 migrations apply --local typix",
		"db:migrate:worker": "wrangler d1 migrations apply --remote typix",
		"create-admin": "npx tsx scripts/create-admin.ts",
		"init:super-admin": "npx tsx scripts/init-super-admin.ts",
		"deploy": "npm run db:migrate:worker && wrangler deploy",
		"deploy:no-migrate": "wrangler deploy"
	},
	"dependencies": {
