# Environment Variables for Node.js Runtime

# MySQL Database Configuration
MYSQL_HOST=""
MYSQL_PORT=""
MYSQL_USER=""
MYSQL_PASSWORD=""
MYSQL_DATABASE=""

# File Storage
FILE_STORAGE="disk" # Options: "base64"(default), "disk", "s3"

# Local File Storage Configuration
FILE_STORAGE_DISK_PATH=".files" # Path to store files locally, default is .files directory

# S3 Object Storage Configuration
# S3_BUCKET="" # S3 bucket name
# S3_REGION="" # AWS region (e.g., us-east-1)
# S3_ACCESS_KEY_ID="" # AWS access key ID
# S3_SECRET_ACCESS_KEY="" # AWS secret access key
# S3_ENDPOINT="" # Optional: Custom S3 endpoint (for S3-compatible services like MinIO, Cloudflare R2)

# Authentication Configuration
AUTH_EMAIL_VERIFICATION_ENABLED="false" # Enable email verification for registration
AUTH_EMAIL_RESEND_API_KEY="" # Resend API key for sending verification emails
AUTH_EMAIL_RESEND_FROM="" # Sender email address for verification emails

# Social Login Configuration
AUTH_SOCIAL_GOOGLE_ENABLED="false" # Enable Google social login
AUTH_SOCIAL_GOOGLE_CLIENT_ID="" # Google OAuth client ID
AUTH_SOCIAL_GOOGLE_CLIENT_SECRET="" # Google OAuth client secret

AUTH_SOCIAL_GITHUB_ENABLED="false" # Enable GitHub social login
AUTH_SOCIAL_GITHUB_CLIENT_ID="" # GitHub OAuth client ID
AUTH_SOCIAL_GITHUB_CLIENT_SECRET="" # GitHub OAuth client secret